dec1 is

  LM : mutate is
  r := LM ! ()->io.stdin.reader LM ! ()->
    for
      sum := 0, sum + 10 * first + last
      l := io.buffered LM .read_line ? s String => s | * => ""
    while l != ""  do
      digits := l.codepoints
                 .filter x->(codepoint.type.ascii_digit.contains x.val)
      first := digits.first.or_panic.parse_i32.or_panic
      last  := digits.last .or_panic.parse_i32.or_panic
    else
      sum

  say r
