dec5 =>

  fr,id := io.stdin.read_string.trim.split "\n\n" .as_tuples.first.or_panic
  fresh := fr.split "\n" .map (.split "-" .map (.parse_i64.or_panic) .as_tuple)
  ids   := id.split "\n" .map (.parse_i64.or_panic)

  part1 =>
    ids.count (i -> fresh ∃ ||>a,b->a<=i<=b)

  part2 =>

  say "$part1:$part2"
